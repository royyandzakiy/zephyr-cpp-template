{
  "name": "nRF Connect SDK (C++)",

  // Small, version-agnostic base image (host tools + nrfutil). Build it once:
  //     docker build -t ncs-base:latest .
  "image": "ncs-base:latest",

  // Mount the SHARED SDK volume. All NCS versions + toolchains live here and
  // are reused by every project/container. Install versions with nrfutil
  // (./scripts/install-sdk.ps1) or the extension's "Manage SDKs" UI — they
  // persist in the volume, so this never re-downloads.
  "mounts": [
    "source=ncs-sdks,target=/opt/nordic/ncs,type=volume"
  ],

  // Default behaviour binds this project folder to /workspaces/<folder-name>.
  // The app is freestanding: it builds against whichever SDK you select in the
  // extension, it does NOT live inside the SDK tree.

  "customizations": {
    "vscode": {
      "extensions": [
        "nordic-semiconductor.nrf-connect-extension-pack",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "marus25.cortex-debug",
        "twxs.cmake"
      ],
      "settings": {
        // The extension auto-discovers installed SDKs/toolchains from nrfutil's
        // configured install dir (set to /opt/nordic/ncs in the image). Pick the
        // SDK version + toolchain per build configuration in the nRF Connect view.
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.cppStandard": "c++23"
      }
    }
  }

  // NOTE: flashing/debugging over J-Link USB from inside a container is not
  // practical on Windows. Build here, flash from the Windows host with nRF Util.
}
